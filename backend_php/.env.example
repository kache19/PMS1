# Database Configuration
DB_HOST=localhost
DB_NAME=malenyap_pms_db
DB_USER=malenyap_user
DB_PASSWORD=your_secure_db_password

# Email / SMTP Configuration
# Popular providers:
#   - SendGrid: smtp.sendgrid.net:587, username: apikey
#   - Mailgun: smtp.mailgun.org:587
#   - Gmail: smtp.gmail.com:587, (use app-specific password)
#   - Mailtrap (testing): smtp.mailtrap.io:587 or 465

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME=Pharmacy System

# Password Reset Configuration
# This is the frontend URL where users can set their new password
# The reset token will be appended as a query parameter
RESET_BASE_URL=http://localhost:3000/auth/reset-password?token=

# Production: Use HTTPS
# RESET_BASE_URL=https://app.yourdomain.com/auth/reset-password?token=
